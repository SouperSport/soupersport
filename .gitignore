## -------------------------------------------------
## Build artifacts (local only)
## -------------------------------------------------

*.exe
*.o

## -------------------------------------------------
## Runtime artifacts (must never be committed)
## -------------------------------------------------

artifacts/

## -------------------------------------------------
## Determinism & execution artifacts
## -------------------------------------------------

# Local sealed scratch inputs (never commit)
cf/

sealed_input.json

# Allow canonical sealed inputs for determinism cases
!examples/**/sealed_input.json

# Generated certificates (never commit directly)
cert1.json
cert2.json
cert_cf.json
*.cert.json

# Allow canonical golden certificates
!examples/**/golden.cert.json

## -------------------------------------------------
## Canonical semantic intake (EXPLICIT EXCEPTION)
## -------------------------------------------------

# Ignore all inputs by default
inputs/**

# Explicitly allow the single governed semantic intake
!inputs/request.json

## -------------------------------------------------
## Signing keys (Stage 9)
## -------------------------------------------------

# Never commit private keys
.keys/*

# Allow committing ONLY the public key JSON (explicit)
!.keys/determinism-signing.public.json

